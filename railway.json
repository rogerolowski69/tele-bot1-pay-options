{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "preDeployCommand": [
      "uv run alembic upgrade head && uv run python scripts/seed_packages.py"
    ],
    "startCommand": "uv run uvicorn apps.api.main:app --host 0.0.0.0 --port ${PORT:-8080}",
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
