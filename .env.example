# Docker
NGINX_PORT=8080

# API
API_SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/telegram_payments
REDIS_URL=redis://redis:6379/0
